{
  "info": {
    "name": "Health Quiz Challenge",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000"
    },
    {
      "key": "sessionId",
      "value": "demo-free-session"
    }
  ],
  "item": [
    {
      "name": "Create session",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "url": "{{baseUrl}}/api/sessions",
        "body": {
          "mode": "raw",
          "raw": "{}"
        }
      }
    },
    {
      "name": "Get progress",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/api/sessions/{{sessionId}}/progress"
      }
    },
    {
      "name": "Get gated result",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/api/sessions/{{sessionId}}/result"
      }
    },
    {
      "name": "Pay callback",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "url": "{{baseUrl}}/pay",
        "body": {
          "mode": "raw",
          "raw": "{\"sessionId\":\"demo-free-session\"}"
        }
      }
    },
    {
      "name": "Get full result",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/api/sessions/{{sessionId}}/result"
      }
    }
  ]
}